DATABASE_URL=postgres://payload:payload@127.0.0.1:5482/payload_draft_post_poc
PAYLOAD_SECRET=local-demo-secret-change-me
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: point Payload at Amazon RDS PostgreSQL instead of local Docker Postgres.
# Download the RDS CA bundle first:
# curl -o global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# DATABASE_URL=postgres://payload:REPLACE_WITH_PASSWORD@REPLACE_WITH_RDS_ENDPOINT:5432/payload_draft_post_poc?sslmode=verify-full&sslrootcert=./global-bundle.pem

# Optional: enable production-like media storage in S3.
# Leave these empty for local filesystem uploads.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
